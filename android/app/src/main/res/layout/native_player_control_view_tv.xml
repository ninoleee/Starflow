<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <View
        android:id="@id/exo_controls_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/native_player_overlay_scrim" />

    <LinearLayout
        android:id="@+id/native_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="@dimen/native_player_tv_horizontal_margin"
        android:layout_marginTop="@dimen/native_player_tv_top_margin"
        android:layout_marginEnd="@dimen/native_player_tv_horizontal_margin"
        android:background="@color/native_player_overlay_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="18dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/native_back"
            android:layout_width="@dimen/native_player_tv_top_button_size"
            android:layout_height="@dimen/native_player_tv_top_button_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/native_back"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/native_player_back_24"
            android:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/native_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/native_title_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/native_player_secondary_text"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@id/exo_center_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:gravity="center"
        android:layoutDirection="ltr"
        android:padding="20dp">

        <include layout="@layout/exo_player_control_rewind_button" />

        <ImageButton
            android:id="@id/exo_play_pause"
            style="@style/ExoStyledControls.Button.Center.PlayPause" />

        <include layout="@layout/exo_player_control_ffwd_button" />
    </LinearLayout>

    <androidx.media3.ui.DefaultTimeBar
        android:id="@id/exo_progress"
        style="@style/ExoStyledControls.TimeBar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/native_player_tv_horizontal_margin"
        android:layout_marginEnd="@dimen/native_player_tv_horizontal_margin"
        android:layout_marginBottom="@dimen/native_player_tv_progress_bottom_margin"
        app:ad_marker_color="@color/native_player_timebar_marker"
        app:bar_height="5dp"
        app:buffered_color="@color/native_player_timebar_buffered"
        app:played_ad_marker_color="@color/native_player_timebar_marker"
        app:played_color="@color/native_player_timebar_played"
        app:scrubber_color="@android:color/white"
        app:scrubber_dragged_size="18dp"
        app:scrubber_enabled_size="14dp"
        app:touch_target_height="32dp"
        app:unplayed_color="@color/native_player_timebar_unplayed" />

    <FrameLayout
        android:id="@id/exo_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/native_player_tv_horizontal_margin"
        android:layout_marginEnd="@dimen/native_player_tv_horizontal_margin"
        android:layout_marginBottom="@dimen/native_player_tv_bottom_margin"
        android:background="@color/native_player_overlay_bar"
        android:layoutDirection="ltr">

        <LinearLayout
            android:id="@id/exo_time"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical|start"
            android:gravity="center_vertical"
            android:layoutDirection="ltr"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:id="@id/exo_position"
                style="@style/ExoStyledControls.TimeText.Position" />

            <TextView
                style="@style/ExoStyledControls.TimeText.Separator" />

            <TextView
                android:id="@id/exo_duration"
                style="@style/ExoStyledControls.TimeText.Duration" />
        </LinearLayout>

        <LinearLayout
            android:id="@id/exo_basic_controls"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical|end"
            android:gravity="center_vertical"
            android:layoutDirection="ltr"
            android:paddingEnd="6dp">

            <ImageButton
                android:id="@id/exo_subtitle"
                style="@style/ExoStyledControls.Button.Bottom.CC" />

            <ImageButton
                android:id="@+id/native_audio_track_button"
                style="@style/ExoStyledControls.Button.Bottom.Settings"
                android:contentDescription="@string/native_audio_track"
                android:src="@drawable/native_player_audio_24" />

            <ImageButton
                android:id="@+id/native_playback_settings"
                style="@style/ExoStyledControls.Button.Bottom.Settings"
                android:contentDescription="@string/native_more_actions"
                android:src="@drawable/native_player_more_24" />
        </LinearLayout>
    </FrameLayout>

</merge>
